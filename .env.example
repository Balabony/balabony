# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ElevenLabs — https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Supabase — https://supabase.com → Project → Settings → API
